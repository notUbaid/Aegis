// Firestore rules for Aegis — development override enabled.
//
// TEMPORARY DEV MODE: Allow authenticated reads on incidents/venues to unblock UI.
// Writes are STILL BLOCKED for clients — use backend Admin SDK only.
// TODO: Remove devModeEnabled() before production deploy.
//
// To enable dev mode for a user, set custom claim `dev_mode: true` in Firebase Auth.
// Or test with emulator where all users are treated as dev.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helpers ==========
    function isSignedIn() {
      return request.auth != null;
    }

    function isVenueMember(venueId) {
      return isSignedIn()
        && request.auth.token.venues != null
        && venueId in request.auth.token.venues;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function hasAnyRole(roles) {
      return isSignedIn() && request.auth.token.role in roles;
    }

    // Dev-mode escape hatch — allows any authenticated user to read anything.
    // Set `dev_mode: true` custom claim on a user to enable.
    function isDevMode() {
      return isSignedIn() && request.auth.token.dev_mode == true;
    }

    // ========== Venues ==========
    match /venues/{venueId} {
      // In production: venue membership required. In dev with dev_mode: allow all.
      allow read: if isVenueMember(venueId) || hasRole('authority_reviewer') || isDevMode();
      allow write: if false;  // Admin SDK only.

      match /zones/{zoneId} {
        allow read: if isVenueMember(venueId) || isDevMode();
        allow write: if false;
      }

      match /cameras/{cameraId} {
        allow read: if isVenueMember(venueId) || isDevMode();
        allow write: if false;
      }

      match /sensors/{sensorId} {
        allow read: if isVenueMember(venueId) || isDevMode();
        allow write: if false;
      }

      match /staff/{staffId} {
        allow read: if isVenueMember(venueId) || isDevMode();
        allow write: if false;
      }

      match /responders/{responderId} {
        allow read: if isVenueMember(venueId) || isDevMode();
        allow write: if false;
      }

      match /chat_rooms/{roomId} {
        allow get: if (isVenueMember(venueId) || isDevMode())
          && request.auth.uid in resource.data.members;
        allow list: if isVenueMember(venueId) || isDevMode();

        match /messages/{messageId} {
          allow read: if isVenueMember(venueId) || isDevMode();
          allow create: if isVenueMember(venueId) || isDevMode()
            && request.auth.uid == request.resource.data.sender_id;
          allow update, delete: if false;
        }
      }
    }

    // ========== Incidents ==========
    match /incidents/{incidentId} {
      // Read: venue members OR authority_reviewer OR dev_mode
      allow read: if (
        isVenueMember(resource.data.venue_id)
        || hasRole('authority_reviewer')
        || isDevMode()
      );
      allow write: if false;  // Admin SDK only.

      match /{subcollection}/{docId} {
        // Read access for incident subcollections
        allow read: if (
          ("venue_id" in resource.data && isVenueMember(resource.data.venue_id))
          || isVenueMember(get(/databases/$(database)/documents/incidents/$(incidentId)).data.venue_id)
          || hasRole('authority_reviewer')
          || isDevMode()
        );

        // Responder ack updates.
        // The responder_id field stores an RSP-* string ("RSP-meera") which is
        // not the same as request.auth.uid (a Firebase UID).  We bridge them by
        // looking up the signed-in user's profile document and comparing its
        // stored responder_id to the dispatch's responder_id.
        allow update: if subcollection == 'dispatches'
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.responder_id == resource.data.responder_id
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['acknowledged_at', 'en_route_at', 'arrived_at', 'notes', 'status']);

        // BLOCK all creates/deletes from client — backend only
        allow create, delete: if false;
      }
    }

    // ========== Users ==========
    match /users/{uid} {
      allow read, update: if isSignedIn() && request.auth.uid == uid;
      // Allow the user to create their own profile document on first sign-in.
      // The uid path segment is enforced so users cannot impersonate each other.
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;

      match /devices/{deviceId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ========== Default deny ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
